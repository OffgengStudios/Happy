# ══════════════════════════════════════════════════════════════════════════════
#  Happy Kollekt — Environment Variables Template
#  Copy this file to .env and fill in every value.
#  .env is gitignored and must NEVER be committed.
# ══════════════════════════════════════════════════════════════════════════════


# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────
# Values: local | staging | production
ENVIRONMENT=staging


# ─── GOOGLE SPREADSHEET IDs ───────────────────────────────────────────────────
# Create a blank Google Sheet and copy the ID from the URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit

# Main database (all 16 canonical tabs live here)
KOLLECT_SPREADSHEET_ID=

# Consent log spreadsheet (can be the same ID as KOLLECT if you keep it in one workbook)
CONSENT_SPREADSHEET_ID=


# ─── GOOGLE DRIVE FOLDER IDs ──────────────────────────────────────────────────
# Create each folder in Drive and copy the ID from the URL:
# https://drive.google.com/drive/folders/<FOLDER_ID>

CV_UPLOAD_FOLDER_ID=
CONSENT_SIGNATURE_FOLDER_ID=
EXPORTS_FOLDER_ID=


# ─── APPS SCRIPT SECRETS ──────────────────────────────────────────────────────
# These are stored in Apps Script PropertiesService (NOT in this file at runtime).
# Run: node scripts/generate-properties-setter.js  to get the .gs snippet to paste.

# Long random string — signs staff session tokens (HMAC-SHA256 key).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
STAFF_SESSION_SECRET=

# Long random string — appended to candidate tokens before hashing (pepper).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_HASH_PEPPER=

# Shared secret between Apps Script and the CV Parser service.
# Must match CV_PARSER_INTEGRATION_SECRET in the CV Parser .env.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CV_PARSER_INTEGRATION_SECRET=

# WhatsApp (Meta Cloud API) — leave blank until Phase 8.
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Your email address — used ONCE to create the first IT Admin account.
# The bootstrap endpoint locks itself after first use.
ADMIN_BOOTSTRAP_EMAIL=


# ─── DEPLOYMENT URLs ──────────────────────────────────────────────────────────
# Fill in after deploying each component.

# Apps Script web app URL (from Deploy → Manage Deployments → Copy URL)
APPS_SCRIPT_DEPLOYMENT_URL=

# GitHub Pages URL for the candidate-facing frontend
CANDIDATE_FRONTEND_URL=

# GitHub Pages URL for staff dashboards
STAFF_DASHBOARD_URL=

# URL of the deployed CV Parser FastAPI service
CV_PARSER_BASE_URL=


# ══════════════════════════════════════════════════════════════════════════════
#  CV PARSER SERVICE  (FastAPI / Python)
#  These variables are read directly by the CV Parser at runtime.
# ══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cvparser

# JWT signing key for the CV Parser's own staff auth (independent of Apps Script)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SECRET_KEY=

# The Apps Script web app URL — CV Parser posts results back here after parsing
APPS_SCRIPT_CALLBACK_URL=

# Same value as CV_PARSER_INTEGRATION_SECRET above — shared secret for the callback
CV_PARSER_INTEGRATION_SECRET=

# WhatsApp (same credentials — CV Parser uses them for media message handling)
# Copy from the APPS SCRIPT section above.
# WHATSAPP_ACCESS_TOKEN=   (already set above — reuse the same value)
# WHATSAPP_PHONE_NUMBER_ID= (already set above)
# WHATSAPP_WEBHOOK_SECRET=  (already set above)

# Set to True only in local development to enable demo login credentials
ENABLE_DEMO_CREDENTIALS=False

# Max upload file size in MB
MAX_UPLOAD_SIZE_MB=10
